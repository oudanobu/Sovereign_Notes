{
  "name": "com.sovereignnote.core",
  "displayName": "SovereignNote Core",
  "version": "1.4.0",
  "description": "Cordova deployment container with high-performance integrated Crosswalk engine",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 0"
  },
  "keywords": [
    "ecosystem:cordova"
  ],
  "author": "SovereignNote Team",
  "license": "Apache-2.0",
  "dependencies": {
    "cordova-android": "^9.1.0",
    "cordova-plugin-crosswalk-webview": "^2.4.0",
    "cordova-plugin-whitelist": "^1.3.4"
  },
  "cordova": {
    "plugins": {
      "cordova-plugin-crosswalk-webview": {
        "XWALK_VERSION": "23+",
        "XWALK_LITEVERSION": "",
        "XWALK_COMMANDLINE": "--disable-pull-to-refresh-effect --ignore-gpu-blacklist",
        "XWALK_MODE": "embedded",
        "XWALK_MULTIPLEAPK": "false"
      },
      "cordova-plugin-whitelist": {}
    },
    "platforms": [
      "android"
    ]
  }
}
